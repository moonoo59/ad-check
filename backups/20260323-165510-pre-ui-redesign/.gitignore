# =============================================
# ad-check .gitignore
# =============================================

# ----- 환경변수 및 자격증명 (절대 커밋 금지) -----
.env
.env.local
.env.*.local

# 스토리지 접속 정보 (IP, 계정, 비밀번호 포함 - 절대 커밋 금지)
storage info.md
"storage info.md"

# ----- 의존성 -----
node_modules/

# ----- 빌드 결과물 -----
dist/
build/

# ----- Electron 패키징 결과물 -----
dist-app/
electron/dist/

# ----- 데이터 (DB 파일은 서버에 남겨두고 커밋하지 않음) -----
data/

# ----- 로그 -----
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# ----- 에디터/IDE -----
.DS_Store
.vscode/settings.json
.idea/
*.swp
*.swo

# ----- TypeScript -----
*.tsbuildinfo
