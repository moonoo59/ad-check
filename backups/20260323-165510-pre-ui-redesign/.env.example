# =============================================
# ad-check 환경변수 설정 예시
# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 채워넣으세요.
# cp .env.example .env
#
# 중요: SMB 비밀번호는 절대 이 파일에 넣지 않는다.
#        macOS Keychain에만 저장한다 (KEYCHAIN 레이블 참조).
# =============================================

# ----- 서버 설정 -----
PORT=4000
NODE_ENV=development

# ----- 데이터베이스 -----
DB_PATH=./data/adcheck.db

# ----- Logger Storage (source: SMB 송출 녹화 스토리지) -----
# macOS 마운트 포인트 경로 (운영자가 수동으로 마운트, 앱은 이 경로 존재 여부만 확인)
LOGGER_STORAGE_MOUNT=/Volumes/data

# ----- 공유 NAS (destination: 광고팀/기술팀 공용 NAS) -----
# macOS 마운트 포인트 경로 (운영자가 수동으로 마운트, 앱은 이 경로 존재 여부만 확인)
SHARED_NAS_MOUNT=/Volumes/광고

# ----- CORS 설정 -----
CORS_ORIGIN=http://localhost:5173

# ----- 세션 설정 -----
# 운영 환경에서는 반드시 강력한 랜덤 값으로 교체할 것
# 예: openssl rand -hex 32
SESSION_SECRET=adcheck-dev-secret-change-in-production

# ----- 프론트엔드 설정 (VITE_ 접두사 필수) -----
VITE_API_BASE_URL=http://localhost:4000/api
