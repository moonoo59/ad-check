# =============================================
# ad-check 환경변수 설정 예시
# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 채워넣으세요.
# cp .env.example .env
#
# 중요: 비밀번호나 민감한 접속 정보는 절대 이 파일에 넣지 않는다.
#        스토리지 인증은 macOS Finder/시스템 자격증명에 맡긴다.
# =============================================

# ----- 서버 설정 -----
PORT=4000
NODE_ENV=development

# 개발 서버와 앱이 함께 쓰는 공용 런타임 데이터 루트
# macOS 기본값: ~/Library/Application Support/AdCheck
# APP_SUPPORT_DIR=/Users/내계정/Library/Application Support/AdCheck

# 내부망 사용자가 접속할 대표 URL
# 예: http://adcheck.tech.net
# 미설정 시 앱/매뉴얼은 http://adcheck.tech.net 을 기본값으로 사용합니다.
# Electron 앱은 create-app 실행 시점의 값을 번들에 저장하므로 운영 주소가 바뀌면 앱을 다시 생성하세요.
PUBLIC_BASE_URL=http://adcheck.tech.net

# ----- 데이터베이스 -----
# 기본값:
# -> ~/Library/Application Support/AdCheck/data/adcheck.db
# 필요할 때만 직접 지정하세요.
# DB_PATH=/Users/내계정/Library/Application Support/AdCheck/data/adcheck.db

# ----- Logger Storage (source: SMB 송출 녹화 스토리지) -----
# macOS 마운트 포인트 경로 (운영자가 수동으로 마운트, 앱은 이 경로 존재 여부만 확인)
LOGGER_STORAGE_MOUNT=/Volumes/data

# ----- 공유 NAS (destination: 기존 NAS, 당분간 하위 호환용 유지) -----
# 과거 호환용 경로. 현재 기본 복사 대상은 LOCAL_DELIVERY_PATH 이므로 보통 수정할 필요가 없습니다.
SHARED_NAS_MOUNT=/Volumes/광고

# ----- 로컬 전달 스토리지 (destination: 서버 로컬 디스크, 웹 다운로드용) -----
# 복사 완료 파일이 저장되는 공용 전달 경로. 1일 후 자동 삭제된다.
# 기본값:
# -> ~/Library/Application Support/AdCheck/data/delivery
# LOCAL_DELIVERY_PATH=/Users/내계정/Library/Application Support/AdCheck/data/delivery

# ----- CORS 설정 -----
# 개발 서버(Vite)에서만 사용. 운영 앱은 같은 오리진으로 서빙됩니다.
CORS_ORIGIN=http://localhost:4000

# ----- 세션 설정 -----
# 개발 환경에서는 아래 기본값을 사용해도 되지만, 운영 환경에서는 반드시 강력한 랜덤 값으로 교체할 것
# 예: openssl rand -hex 32
# Electron 패키징 앱은 최초 실행 시 userData 아래에 설치별 랜덤 시크릿을 자동 생성/보관한다.
SESSION_SECRET=adcheck-dev-secret-change-in-production

# ----- 프론트엔드 설정 (선택) -----
# 운영 앱/같은 오리진 배포에서는 보통 비워두고 상대경로(/api)를 사용합니다.
# 별도 프론트엔드 배포가 필요할 때만 frontend/.env 등에 설정하세요.
# VITE_API_BASE_URL=/api
